ADMIN_PASSWORD="admin123"
ADMIN_SESSION_SECRET="troque-este-segredo-no-servidor-linux"
APP_URL="http://localhost:3001"

# Local: use "console" to print password reset links in the server log.
# Homologacao/producao sem Docker: use MAIL_DRIVER="smtp" e SMTP_HOST="127.0.0.1".
# Homologacao/producao em Docker com Postfix no host: use SMTP_HOST="host.docker.internal"
# e permita a rede Docker interna no Postfix.
MAIL_DRIVER="console"
MAIL_FROM="Provas DCER Paulista <no-reply@localhost>"
SMTP_HOST=""
SMTP_PORT="25"
SMTP_SECURE="false"
SMTP_REQUIRE_TLS="false"
SMTP_IGNORE_TLS="false"
SMTP_USER=""
SMTP_PASSWORD=""
